<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Task Manager" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Task Manager">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-black text-gray-200 min-h-screen flex flex-col">

    <header class="bg-zinc-900 border-b border-zinc-800 sticky top-0 z-50 shadow-md">
      <div class="max-w-2xl mx-auto px-6">
        <div class="flex items-center justify-between h-16">
          
          <%= link_to root_path, class: "flex items-center gap-2 hover:opacity-80 transition-opacity" do %>
            <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span class="text-green-500 font-bold text-xl tracking-tight">TaskManager</span>
          <% end %>

          <nav class="flex space-x-2">
            <%= link_to "Tasks", root_path, 
                class: "text-zinc-300 hover:bg-zinc-800 hover:text-green-400 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
            
            <%= link_to "Categories", categories_path, 
                class: "text-zinc-300 hover:bg-zinc-800 hover:text-green-400 px-3 py-2 rounded-md text-sm font-medium transition-colors" %>
          </nav>

        </div>
      </div>
    </header>

    <div class="w-full max-w-2xl mx-auto px-6 mt-6">
      <% flash.each do |type, message| %>
        <p class="px-4 py-3 rounded-lg text-sm font-medium shadow text-center <%= type == 'notice' ? 'bg-green-600 text-black' : 'bg-red-600 text-white' %>">
          <%= message %>
        </p>
      <% end %>
    </div>

    <main class="flex-grow w-full max-w-2xl mx-auto px-6 py-8">
      <%= yield %>
    </main>


  </body>
</html>