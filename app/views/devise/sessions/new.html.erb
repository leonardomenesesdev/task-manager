<div class="max-w-md mx-auto mt-16 bg-zinc-900 border border-zinc-800 rounded-2xl p-8 shadow-lg">
  
  <div class="text-center mb-8">
    <h2 class="text-3xl font-extrabold text-green-500">Log In</h2>
    <p class="text-zinc-400 text-sm mt-2">Welcome back to Task Manager</p>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
    
    <div>
      <%= f.label :email, class: "block text-sm font-medium text-zinc-300 mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full bg-zinc-800 border border-zinc-700 text-zinc-200 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-colors" %>
    </div>

    <div>
      <%= f.label :password, class: "block text-sm font-medium text-zinc-300 mb-1" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "w-full bg-zinc-800 border border-zinc-700 text-zinc-200 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent transition-colors" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="flex items-center gap-2 mt-2">
        <%= f.check_box :remember_me, class: "w-4 h-4 text-green-600 bg-zinc-800 border-zinc-700 rounded focus:ring-green-500 focus:ring-offset-zinc-900 focus:ring-2 cursor-pointer accent-green-600" %>
        <%= f.label :remember_me, class: "text-sm text-zinc-400 cursor-pointer select-none" %>
      </div>
    <% end %>

    <div class="pt-4">
      <%= f.submit "Log In", class: "w-full bg-green-600 hover:bg-green-500 text-black font-bold text-lg px-6 py-3 rounded-lg transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 pt-6 border-t border-zinc-800 flex flex-col gap-3 text-center text-sm text-green-400 hover:text-green-300 transition-colors">
    <%= render "devise/shared/links" %>
  </div>

</div>