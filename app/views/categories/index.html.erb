<p class="text-green-400 mb-4 text-center"><%= notice %></p>

<% content_for :title, "Categories" %>

<h1 class="text-3xl font-bold text-green-500 mb-6 text-center">
  Categories
</h1>

<div id="categories" class="space-y-4">

  <% @categories.each do |category| %>

    <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-6 shadow-lg">

      <%= render category %>

      <p class="mt-4">
        <%= link_to "Show this category", category,
        class: "text-green-400 hover:text-green-300 font-medium transition-colors" %>
      </p>

    </div>

  <% end %>

</div>

<div class="mt-8 flex justify-center items-center gap-4">
  
  <%= link_to "Back to Menu", root_path, 
      class: "bg-zinc-800 border border-zinc-700 hover:bg-zinc-700 text-zinc-300 font-semibold px-6 py-2 rounded-lg transition-colors" %>

  <%= link_to "New category", new_category_path,
      class: "bg-green-600 hover:bg-green-500 text-black font-semibold px-6 py-2 rounded-lg transition-colors" %>

</div>