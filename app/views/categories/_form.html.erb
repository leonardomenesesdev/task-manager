<%= form_with(model: category, class: "space-y-6") do |form| %>

  <% if category.errors.any? %>

    <div class="bg-red-900 border border-red-500 text-red-200 p-4 rounded-lg">

      <h2 class="font-semibold mb-2">
        <%= pluralize(category.errors.count, "error") %> prohibited this category from being saved:
      </h2>

      <ul class="list-disc list-inside text-sm space-y-1">
        <% category.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>

    </div>

  <% end %>

  <div class="flex flex-col gap-2">

    <%= form.label :name, class: "text-green-400 font-medium" %>

    <%= form.text_field :name,
      class: "bg-black border border-zinc-700 rounded-lg px-3 py-2 text-gray-200 focus:outline-none focus:ring-2 focus:ring-green-500" %>

  </div>

  <div>

    <%= form.submit "Save Category",
      class: "bg-green-600 hover:bg-green-500 text-black font-semibold px-4 py-2 rounded-lg shadow cursor-pointer" %>

  </div>

<% end %>